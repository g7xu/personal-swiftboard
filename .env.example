# PostgreSQL — defaults match docker-compose.yml (container on port 5433)
DATABASE_URL="postgresql://swiftboard:swiftboard@localhost:5433/swiftboard"
DIRECT_URL="postgresql://swiftboard:swiftboard@localhost:5433/swiftboard"

# NextAuth
AUTH_SECRET=""            # generate with: openssl rand -hex 32
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI task analysis
AI_PROVIDER="gemini"      # "gemini" (default) or "claude"
GEMINI_API_KEY=""         # create at https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=""      # only needed when AI_PROVIDER=claude
